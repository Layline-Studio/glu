---
interface Props {
  showFeaturedIn?: boolean;
}

const { showFeaturedIn: _showFeaturedIn = false } = Astro.props;
---

<footer class="border-t border-slate-200/80 bg-surface-raised">
  <div class="mx-auto max-w-screen-xl px-6 py-12 sm:px-10 sm:py-16">
    <div class="flex flex-col items-center justify-between gap-6 sm:flex-row">
      <a href="/" class="flex items-center gap-2.5">
        <img
          src="/app_icon.png"
          alt=""
          class="h-7 w-7 rounded-lg"
          width="28"
          height="28"
          loading="lazy"
        />
        <span class="font-display text-base font-bold tracking-tight text-ink">Glu</span>
      </a>
      <div class="flex flex-wrap items-center justify-center gap-7 text-sm text-ink-soft">
        <a href="/terms" class="transition-colors hover:text-ink">Terms</a>
        <a href="/privacy" class="transition-colors hover:text-ink">Privacy</a>
        <a href="/support" class="transition-colors hover:text-ink">Support</a>
      </div>
      <p class="text-sm text-ink-faint">&copy; 2026 Layline Ventures</p>
    </div>

    <div class="mt-10 h-px w-full bg-linear-to-r from-transparent via-slate-200 to-transparent"></div>

    <div class="mx-auto mt-8 max-w-3xl text-center">
      <p class="text-xs font-semibold uppercase tracking-[0.18em] text-ink-faint">Medical Disclaimer</p>
      <p class="mt-3 text-[13px] leading-relaxed text-ink-faint">
        Glu is intended for personal tracking and educational use only. It does not provide medical advice, diagnosis, or treatment, and should not be used as a substitute for guidance from a licensed physician or other qualified healthcare professional. Always consult your healthcare provider before making decisions about medication, dosing, nutrition, exercise, or any aspect of your treatment plan.
      </p>
    </div>
  </div>
</footer>
