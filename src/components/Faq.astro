---
import { homeFaqs } from '../data/homeFaqs';
---

<section id="faq" class="bg-surface px-6 py-28 sm:px-10 sm:py-36" aria-label="Frequently asked questions">
    <div class="mx-auto w-full max-w-screen-xl">
        <div class="max-w-3xl">
            <h2
                data-reveal
                class="font-display text-[clamp(2rem,4.5vw,3.4rem)] font-bold leading-[1.06] tracking-[-0.025em] text-ink"
            >
                Questions people ask about GLP&#8209;1 tracking
            </h2>
            <p
                data-reveal
                style="--reveal-delay: 0.08s"
                class="mt-6 max-w-2xl text-base leading-relaxed text-ink-soft sm:text-lg"
            >
                A deeper set of answers about pricing, supported routines,
                integrations, privacy, and how a GLP&#8209;1 tracker fits into
                everyday treatment.
            </p>
        </div>

        <div class="mt-14 grid gap-5 lg:grid-cols-2">
            {
                homeFaqs.map((faq, index) => (
                    <details
                        data-reveal
                        style={`--reveal-delay: ${index * 0.06}s`}
                        class="group rounded-[1.75rem] border border-slate-200 bg-white p-7 shadow-[0_24px_60px_-44px_rgba(15,23,42,0.22)] sm:p-8"
                    >
                        <summary class="flex cursor-pointer list-none items-start justify-between gap-4 marker:hidden">
                            <h3 class="font-display text-xl font-bold leading-[1.14] tracking-[-0.015em] text-ink">
                                {faq.question}
                            </h3>
                            <span class="mt-1 shrink-0 text-2xl leading-none text-ink-faint transition-transform duration-300 group-open:rotate-45">
                                +
                            </span>
                        </summary>
                        <p class="mt-4 pr-8 text-[15px] leading-relaxed text-ink-soft sm:text-base">
                            {faq.answer}
                        </p>
                    </details>
                ))
            }
        </div>
    </div>
</section>
