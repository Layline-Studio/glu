---
const target = '/en-US/';
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta http-equiv="refresh" content={`0; url=${target}`} />
    <meta name="robots" content="noindex,follow" />
    <link rel="canonical" href="https://myglu.health/en-US/" />
    <script is:inline>
      window.location.replace('/en-US/');
    </script>
    <title>Redirecting…</title>
  </head>
  <body>
    <p>
      Redirecting to
      <a href={target}>{target}</a>
    </p>
  </body>
</html>
