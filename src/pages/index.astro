---
import Layout from '../layouts/Layout.astro';
import { getImage } from 'astro:assets';
import Nav from '../components/Nav.astro';
import Hero from '../components/Hero.astro';
import Showcase from '../components/Showcase.astro';
import Trust from '../components/Trust.astro';
import Faq from '../components/Faq.astro';
import Cta from '../components/Cta.astro';
import Footer from '../components/Footer.astro';
import homeTrackers from '../assets/landing-page/home_trackers.png';

const description =
  'Glu is a GLP-1 tracker for reminders, dose history, weight trends, side effects, meals, water, and daily progress.';

const heroPreload = await getImage({
  src: homeTrackers,
  width: 480,
  format: 'webp',
});

const heroPreloadLarge = await getImage({
  src: homeTrackers,
  width: 860,
  format: 'webp',
});

const structuredData = [
  {
    '@context': 'https://schema.org',
    '@type': 'Organization',
    name: 'Glu',
    url: 'https://myglu.health',
    logo: 'https://myglu.health/app_icon.png',
    email: 'support@myglu.health',
    sameAs: ['https://www.instagram.com/myglu.health/'],
  },
  {
    '@context': 'https://schema.org',
    '@type': 'SoftwareApplication',
    name: 'Glu',
    applicationCategory: 'HealthApplication',
    operatingSystem: 'iOS, Android',
    description,
    url: 'https://myglu.health',
    image: 'https://myglu.health/app_icon.png',
    offers: [
      {
        '@type': 'Offer',
        name: 'Monthly plan',
        price: '9.99',
        priceCurrency: 'USD',
        description: 'Monthly subscription',
      },
      {
        '@type': 'Offer',
        name: 'Annual plan',
        price: '89.99',
        priceCurrency: 'USD',
        description: 'Annual subscription',
      },
    ],
    downloadUrl: [
      'https://play.google.com/store/apps/details?id=ventures.layline.glu',
      'https://apps.apple.com/us/app/glu-glp-1-weight-loss-tracker/id6761419458',
    ],
  },
  {
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: [
      {
        '@type': 'Question',
        name: 'What does Glu track?',
        acceptedAnswer: {
          '@type': 'Answer',
          text: 'Glu helps track medication reminders, dose history, weight trends, meals, water, movement, symptoms, and day-to-day progress in one place.',
        },
      },
      {
        '@type': 'Question',
        name: 'Which GLP-1 medications does Glu support?',
        acceptedAnswer: {
          '@type': 'Answer',
          text: 'Glu is built for people using GLP-1 treatments across common shots and pills, including medications such as Zepbound, Mounjaro, Ozempic, Wegovy, and Rybelsus.',
        },
      },
      {
        '@type': 'Question',
        name: 'Can Glu help me notice patterns while on GLP-1?',
        acceptedAnswer: {
          '@type': 'Answer',
          text: 'Yes. Glu is designed to make it easier to compare reminders, doses, meals, symptoms, and progress over time so changes feel easier to interpret.',
        },
      },
      {
        '@type': 'Question',
        name: 'Why do people on GLP-1 track meals, symptoms, and weight together?',
        acceptedAnswer: {
          '@type': 'Answer',
          text: 'Many people want one record of how treatment timing, appetite, food choices, symptoms, and weight changes line up over time. Glu keeps those details together so the overall picture is easier to follow.',
        },
      },
      {
        '@type': 'Question',
        name: 'Does Glu replace medical advice?',
        acceptedAnswer: {
          '@type': 'Answer',
          text: 'No. Glu is for personal tracking and education only. It does not diagnose, treat, or replace guidance from a licensed healthcare professional.',
        },
      },
      {
        '@type': 'Question',
        name: 'How does Glu handle privacy and account deletion?',
        acceptedAnswer: {
          '@type': 'Answer',
          text: 'Glu links directly to its privacy policy and account deletion instructions, and you can contact support if you need help with account-related requests.',
        },
      },
    ],
  },
];
---

<Layout
  title="Glu | GLP-1 Tracker for Daily Progress"
  description={description}
  structuredData={structuredData}
  preloadImage={{
    href: heroPreload.src,
    srcset: `${heroPreload.src} 480w, ${heroPreloadLarge.src} 860w`,
    sizes: '(min-width: 1024px) 430px, 360px',
    type: 'image/webp',
  }}
>
  <div class="relative min-h-screen bg-surface text-slate-900">
    <Nav />
    <Hero />
    <Showcase />
    <Trust />
    <Faq />
    <Cta />
    <Footer />
  </div>
</Layout>
