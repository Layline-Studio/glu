---
import StoreButtons from './StoreButtons.astro';

interface Props {
  copy: {
    title: string;
    intro: string;
    plans: Array<{
      name: string;
      price: string;
      cadence: string;
      note: string;
      badge: string | null;
    }>;
    includesTitle: string;
    includes: string[];
    note: string;
  };
}

const { copy } = Astro.props;
---

<section id="pricing" class="bg-surface px-6 py-28 sm:px-10 sm:py-36" aria-label="Pricing">
  <div class="mx-auto w-full max-w-screen-xl">
    <div class="max-w-3xl">
      <h2
        data-reveal
        class="font-display text-[clamp(2rem,4.5vw,3.4rem)] font-bold leading-[1.06] tracking-[-0.025em] text-ink"
      >
        {copy.title}
      </h2>
      <p
        data-reveal
        style="--reveal-delay: 0.08s"
        class="mt-6 max-w-2xl text-base leading-relaxed text-ink-soft sm:text-lg"
      >
        {copy.intro}
      </p>
    </div>

    <div class="mt-14 grid gap-6 lg:grid-cols-[1.1fr_0.9fr]">
      <div class="grid gap-5 sm:grid-cols-2">
        {
          copy.plans.map((plan, index) => (
            <article
              data-reveal
              style={`--reveal-delay: ${index * 0.08}s`}
              class={`rounded-[2rem] border bg-white p-7 shadow-[0_24px_60px_-44px_rgba(15,23,42,0.22)] sm:p-8 ${
                plan.badge ? 'border-brand/25 ring-1 ring-brand/10' : 'border-slate-200'
              }`}
            >
              <div class="flex items-start justify-between gap-4">
                <p class="text-sm font-semibold uppercase tracking-[0.18em] text-ink-faint">
                  {plan.name}
                </p>
                {plan.badge && (
                  <span class="inline-flex rounded-full bg-brand px-3 py-1 text-[11px] font-semibold uppercase tracking-[0.16em] text-white">
                    {plan.badge}
                  </span>
                )}
              </div>
              <div class="mt-5 flex items-end gap-2">
                <span class="font-display text-4xl font-bold tracking-[-0.03em] text-ink sm:text-5xl">
                  {plan.price}
                </span>
                <span class="pb-1 text-sm text-ink-soft sm:text-base">
                  {plan.cadence}
                </span>
              </div>
              <p class="mt-4 text-[15px] leading-relaxed text-ink-soft sm:text-base">
                {plan.note}
              </p>
            </article>
          ))
        }
      </div>

      <div
        data-reveal
        style="--reveal-delay: 0.12s"
        class="rounded-[2rem] border border-slate-200 bg-surface-raised p-7 sm:p-8"
      >
        <h3 class="font-display text-2xl font-bold leading-[1.12] tracking-[-0.02em] text-ink">
          {copy.includesTitle}
        </h3>
        <ul class="mt-6 space-y-4">
          {
            copy.includes.map((item) => (
              <li class="flex gap-3 text-[15px] leading-relaxed text-ink-soft sm:text-base">
                <span class="mt-1 h-2.5 w-2.5 rounded-full bg-brand"></span>
                <span>{item}</span>
              </li>
            ))
          }
        </ul>
        <p class="mt-6 text-sm leading-relaxed text-ink-faint sm:text-base">
          {copy.note}
        </p>
        <div class="mt-6">
          <StoreButtons />
        </div>
      </div>
    </div>
  </div>
</section>
