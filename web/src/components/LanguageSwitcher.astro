---
interface Props {
  currentLocale: string;
  links: Array<{
    locale: string;
    label: string;
    href: string;
  }>;
}

const { currentLocale, links } = Astro.props;
---

<div class="relative inline-flex items-center gap-2 rounded-full border border-slate-200 bg-white py-2 pl-3.5 pr-9 transition-colors hover:border-slate-300 focus-within:border-slate-300">
  <svg
    class="h-4 w-4 shrink-0 text-ink-faint"
    viewBox="0 0 24 24"
    fill="none"
    stroke="currentColor"
    stroke-width="1.7"
    aria-hidden="true"
  >
    <circle cx="12" cy="12" r="9" />
    <path d="M3 12h18" stroke-linecap="round" />
    <path d="M12 3c2.6 2.5 2.6 15.5 0 18M12 3c-2.6 2.5-2.6 15.5 0 18" stroke-linecap="round" />
  </svg>
  <select
    data-lang-switcher
    aria-label="Choose language"
    class="cursor-pointer appearance-none bg-transparent text-xs font-semibold tracking-wide text-ink-soft transition-colors hover:text-ink focus:outline-none"
  >
    {links.map((link) => (
      <option value={link.href} selected={link.locale === currentLocale}>
        {link.label}
      </option>
    ))}
  </select>
  <svg
    class="pointer-events-none absolute right-3.5 h-3.5 w-3.5 text-ink-faint"
    viewBox="0 0 20 20"
    fill="none"
    stroke="currentColor"
    stroke-width="1.8"
    aria-hidden="true"
  >
    <path d="M6 8l4 4 4-4" stroke-linecap="round" stroke-linejoin="round" />
  </svg>
</div>

<script>
  document.querySelectorAll('select[data-lang-switcher]').forEach((select) => {
    select.addEventListener('change', (event) => {
      const target = event.currentTarget as HTMLSelectElement;
      if (target.value) window.location.href = target.value;
    });
  });
</script>
