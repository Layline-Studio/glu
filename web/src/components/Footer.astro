---
import LanguageSwitcher from './LanguageSwitcher.astro';

interface Props {
  showFeaturedIn?: boolean;
  homeHref?: string;
  links?: {
    about: string;
    contact: string;
    terms: string;
    privacy: string;
    support: string;
  };
  resourceLinks?: {
    guides: string;
    glossary: string;
    printable: string;
  };
  disclaimerTitle?: string;
  disclaimerBody?: string;
  copyright?: string;
  currentLocale?: string;
  languageLinks?: Array<{
    locale: string;
    label: string;
    href: string;
  }>;
}

const {
  showFeaturedIn: _showFeaturedIn = false,
  homeHref = '/',
  links = {
    about: 'About',
    contact: 'Contact',
    terms: 'Terms',
    privacy: 'Privacy',
    support: 'Support',
  },
  resourceLinks = {
    guides: 'GLP-1 Guides',
    glossary: 'Glossary',
    printable: 'Free Shot Tracker',
  },
  disclaimerTitle = 'Medical Disclaimer',
  disclaimerBody = 'Glu is intended for personal tracking and educational use only. It does not provide medical advice, diagnosis, or treatment, and should not be used as a substitute for guidance from a licensed physician or other qualified healthcare professional. Always consult your healthcare provider before making decisions about medication, dosing, nutrition, exercise, or any aspect of your treatment plan.',
  copyright = '© 2026 Layline Ventures',
  currentLocale = 'en-US',
  languageLinks = [],
} = Astro.props;
---

<footer class="border-t border-slate-200/80 bg-surface-raised">
  <div class="mx-auto max-w-screen-xl px-6 py-12 sm:px-10 sm:py-16">
    <div class="flex flex-col items-center justify-between gap-6 sm:flex-row">
      <a href={homeHref} class="flex items-center gap-2.5">
        <img
          src="/app_icon.png"
          alt=""
          class="h-7 w-7 rounded-lg"
          width="28"
          height="28"
          loading="lazy"
        />
        <span class="font-display text-base font-bold tracking-tight text-ink">Glu</span>
      </a>
      <div class="flex flex-wrap items-center justify-center gap-7 text-sm text-ink-soft">
        <a href="/about" class="transition-colors hover:text-ink">{links.about}</a>
        <a href="/guides" class="transition-colors hover:text-ink">{resourceLinks.guides}</a>
        <a href="/glossary" class="transition-colors hover:text-ink">{resourceLinks.glossary}</a>
        <a href="/printable-glp-1-tracker" class="transition-colors hover:text-ink">{resourceLinks.printable}</a>
        <a href="/support" class="transition-colors hover:text-ink">{links.contact}</a>
        <a href="/terms" class="transition-colors hover:text-ink">{links.terms}</a>
        <a href="/privacy" class="transition-colors hover:text-ink">{links.privacy}</a>
        <a href="/support" class="transition-colors hover:text-ink">{links.support}</a>
      </div>
      <p class="text-sm text-ink-faint">{copyright}</p>
    </div>

    {languageLinks.length > 0 && (
      <div class="mt-6 flex justify-center">
        <LanguageSwitcher currentLocale={currentLocale} links={languageLinks} />
      </div>
    )}

    <div class="mt-10 h-px w-full bg-linear-to-r from-transparent via-slate-200 to-transparent"></div>

    <div class="mx-auto mt-8 max-w-3xl text-center">
      <p class="text-xs font-semibold uppercase tracking-[0.18em] text-ink-faint">{disclaimerTitle}</p>
      <p class="mt-3 text-[13px] leading-relaxed text-ink-faint">
        {disclaimerBody}
      </p>
    </div>
  </div>
</footer>
