---
import { getCollection, getEntry, render } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import Footer from '../../components/Footer.astro';

export async function getStaticPaths() {
  const entries = await getCollection('glossary');
  return entries.map((entry) => ({ params: { slug: entry.id }, props: { entry } }));
}

const { entry } = Astro.props;
const { Content } = await render(entry);

const relatedGuides = (
  await Promise.all(entry.data.related.map((id) => getEntry('guides', id)))
).filter((guide) => guide !== undefined);

const canonicalPath = `/glossary/${entry.id}`;

const structuredData = [
  {
    '@context': 'https://schema.org',
    '@type': 'DefinedTerm',
    name: entry.data.title,
    description: entry.data.description,
    url: `https://myglu.health${canonicalPath}`,
    inDefinedTermSet: {
      '@type': 'DefinedTermSet',
      name: 'Glu GLP-1 Glossary',
      url: 'https://myglu.health/glossary',
    },
  },
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://myglu.health/' },
      { '@type': 'ListItem', position: 2, name: 'Glossary', item: 'https://myglu.health/glossary' },
      { '@type': 'ListItem', position: 3, name: entry.data.title, item: `https://myglu.health${canonicalPath}` },
    ],
  },
];
---

<Layout
  title={`${entry.data.title} — Definition | Glu Glossary`}
  description={entry.data.description}
  canonicalPath={canonicalPath}
  structuredData={structuredData}
>
  <div class="min-h-screen bg-slate-50 text-slate-900">
    <header class="sticky top-0 z-50 border-b border-slate-100 bg-white/80 backdrop-blur-xl">
      <div class="mx-auto max-w-screen-md px-6 py-6 sm:px-8">
        <a href="/" class="inline-flex items-center gap-3">
          <img src="/app_icon.png" alt="Glu" class="h-8 w-8 rounded-xl shadow-sm" width="32" height="32" />
          <span class="font-sora text-lg font-semibold tracking-tight text-slate-900">Glu</span>
        </a>
      </div>
    </header>

    <article class="mx-auto w-full max-w-screen-md px-6 pb-20 pt-14 sm:px-8 sm:pt-16">
      <a href="/glossary" class="text-sm font-medium text-slate-500 transition-colors hover:text-slate-900">
        ← Glossary
      </a>
      <h1 class="mt-6 font-sora text-3xl font-semibold leading-tight tracking-tight text-slate-900 sm:text-4xl">
        {entry.data.title}
      </h1>

      <div class="prose prose-slate mt-8 max-w-none prose-headings:font-sora prose-headings:tracking-tight prose-a:text-blue-600 prose-a:no-underline hover:prose-a:underline">
        <Content />
      </div>

      {relatedGuides.length > 0 && (
        <div class="mt-12 rounded-3xl border border-slate-100 bg-white p-7 shadow-[0_24px_60px_-50px_rgba(15,23,42,0.6)]">
          <p class="text-xs font-semibold uppercase tracking-[0.18em] text-slate-500">Go deeper</p>
          <ul class="mt-4 flex flex-col gap-3">
            {relatedGuides.map((guide) => (
              <li>
                <a href={`/guides/${guide.id}`} class="text-sm font-semibold text-blue-600 transition-colors hover:text-blue-500">
                  {guide.data.title} →
                </a>
              </li>
            ))}
          </ul>
        </div>
      )}
    </article>

    <Footer />
  </div>
</Layout>
