---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import Footer from '../../components/Footer.astro';

const entries = (await getCollection('glossary')).sort((a, b) =>
  a.data.title.localeCompare(b.data.title),
);

const structuredData = [
  {
    '@context': 'https://schema.org',
    '@type': 'DefinedTermSet',
    name: 'Glu GLP-1 Glossary',
    description: 'Plain-language definitions of GLP-1 treatment, medication, and weight-management terms.',
    url: 'https://myglu.health/glossary',
  },
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://myglu.health/' },
      { '@type': 'ListItem', position: 2, name: 'Glossary', item: 'https://myglu.health/glossary' },
    ],
  },
];
---

<Layout
  title="GLP-1 Glossary — Plain-Language Definitions | Glu"
  description="Food noise, shot day, titration, maintenance dose, plateau — every term of the GLP-1 world, defined in plain language with links to deeper guides."
  canonicalPath="/glossary"
  structuredData={structuredData}
>
  <div class="min-h-screen bg-slate-50 text-slate-900">
    <header class="sticky top-0 z-50 border-b border-slate-100 bg-white/80 backdrop-blur-xl">
      <div class="mx-auto max-w-screen-md px-6 py-6 sm:px-8">
        <a href="/" class="inline-flex items-center gap-3">
          <img src="/app_icon.png" alt="Glu" class="h-8 w-8 rounded-xl shadow-sm" width="32" height="32" />
          <span class="font-sora text-lg font-semibold tracking-tight text-slate-900">Glu</span>
        </a>
      </div>
    </header>

    <main class="mx-auto w-full max-w-screen-md px-6 pb-20 sm:px-8">
      <div class="pb-8 pt-16 sm:pt-20">
        <span class="inline-flex items-center gap-2 rounded-full bg-slate-900/5 px-3 py-1 text-xs font-semibold uppercase tracking-[0.2em] text-slate-700">
          Glossary
        </span>
        <h1 class="mt-5 font-sora text-3xl font-semibold tracking-tight text-slate-900 sm:text-4xl">
          The GLP-1 dictionary
        </h1>
        <p class="mt-4 max-w-2xl text-lg leading-relaxed text-slate-500">
          Every term you'll meet during GLP-1 treatment — from your prescriber, in support groups,
          and online — defined in plain language, with links to the full guides where one exists.
        </p>
      </div>

      <div class="grid gap-4 sm:grid-cols-2">
        {entries.map((entry) => (
          <a
            href={`/glossary/${entry.id}`}
            class="group rounded-3xl border border-slate-100 bg-white p-6 shadow-[0_24px_60px_-50px_rgba(15,23,42,0.6)] transition-all duration-300 ease-out-quint hover:-translate-y-1"
          >
            <h2 class="font-sora text-base font-semibold text-slate-900 transition-colors group-hover:text-blue-600">
              {entry.data.title}
            </h2>
            <p class="mt-2 text-sm leading-relaxed text-slate-500">{entry.data.description}</p>
          </a>
        ))}
      </div>

      <div class="mt-16 rounded-3xl border border-slate-100 bg-white px-6 py-8 text-center shadow-[0_24px_60px_-50px_rgba(15,23,42,0.6)] sm:px-10">
        <p class="font-sora text-lg font-semibold text-slate-900">Want the full picture, not just the words?</p>
        <p class="mt-2 text-sm leading-relaxed text-slate-500">
          Our guides cover shot day, side effects, eating, and plateaus in practical depth.
        </p>
        <a
          href="/guides"
          class="mt-5 inline-flex items-center rounded-full bg-slate-950 px-5 py-2.5 text-sm font-semibold text-white transition-all duration-300 ease-out-quint hover:-translate-y-0.5 hover:bg-slate-900"
        >
          Browse all guides
        </a>
      </div>
    </main>

    <Footer />
  </div>
</Layout>
