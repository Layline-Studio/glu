---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import Footer from '../../components/Footer.astro';

export async function getStaticPaths({ paginate }) {
  const pageSize = 9;
  const guides = (await getCollection('guides', ({ data }) => !data.draft)).sort(
    (a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
  );

  return paginate(guides, { pageSize });
}

const { page } = Astro.props;
const currentPage = page.currentPage;
const totalPages = page.lastPage;
const canonicalPath = currentPage === 1 ? '/guides' : `/guides/${currentPage}`;
const title =
  currentPage === 1
    ? 'GLP-1 Guides — Practical Help for Treatment Weeks | Glu'
    : `GLP-1 Guides, Page ${currentPage} | Glu`;

const pageHref = (pageNumber: number) => (pageNumber === 1 ? '/guides' : `/guides/${pageNumber}`);

const formatDate = (date: Date) =>
  date.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' });

const structuredData = {
  '@context': 'https://schema.org',
  '@type': 'BreadcrumbList',
  itemListElement: [
    { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://myglu.health/' },
    { '@type': 'ListItem', position: 2, name: 'Guides', item: 'https://myglu.health/guides' },
  ],
};
---

<Layout
  title={title}
  description="Practical, evidence-based guides for life on GLP-1 medications: shot day, side effects, food, plateaus, and tracking your progress week by week."
  canonicalPath={canonicalPath}
  structuredData={structuredData}
>
  <div class="min-h-screen bg-slate-50 text-slate-900">
    <header class="sticky top-0 z-50 border-b border-slate-100 bg-white/80 backdrop-blur-xl">
      <div class="mx-auto max-w-screen-lg px-6 py-6 sm:px-8">
        <a href="/" class="inline-flex items-center gap-3">
          <img src="/app_icon.png" alt="Glu" class="h-8 w-8 rounded-xl shadow-sm" width="32" height="32" />
          <span class="font-sora text-lg font-semibold tracking-tight text-slate-900">Glu</span>
        </a>
      </div>
    </header>

    <main class="mx-auto w-full max-w-screen-lg px-6 pb-20 sm:px-8">
      <div class="pb-8 pt-16 sm:pt-20">
        <span class="inline-flex items-center gap-2 rounded-full bg-slate-900/5 px-3 py-1 text-xs font-semibold uppercase tracking-[0.2em] text-slate-700">
          Guides
        </span>
        <h1 class="mt-5 font-sora text-3xl font-semibold tracking-tight text-slate-900 sm:text-4xl">
          Practical guides for GLP-1 treatment weeks
        </h1>
        <p class="mt-4 max-w-2xl text-lg leading-relaxed text-slate-500">
          Shot day, side effects, eating, plateaus, progress — what the research says and what to
          actually do, written for people in treatment, not clinicians.
        </p>
      </div>

      <div class="grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
        {page.data.map((guide) => (
          <a
            href={`/guides/${guide.id}`}
            class="group flex flex-col rounded-3xl border border-slate-100 bg-white p-6 shadow-[0_24px_60px_-50px_rgba(15,23,42,0.6)] transition-all duration-300 ease-out-quint hover:-translate-y-1"
          >
            <h2 class="font-sora text-base font-semibold leading-snug text-slate-900 transition-colors group-hover:text-blue-600">
              {guide.data.title}
            </h2>
            <p class="mt-3 flex-1 text-sm leading-relaxed text-slate-500">
              {guide.data.description}
            </p>
            <time
              datetime={guide.data.pubDate.toISOString()}
              class="mt-5 text-xs font-medium uppercase tracking-[0.14em] text-slate-400"
            >
              {formatDate(guide.data.updatedDate ?? guide.data.pubDate)}
            </time>
          </a>
        ))}
      </div>

      {totalPages > 1 && (
        <nav class="mt-12 flex items-center justify-center gap-2" aria-label="Guides pagination">
          {Array.from({ length: totalPages }, (_, index) => index + 1).map((pageNumber) => (
            <a
              href={pageHref(pageNumber)}
              aria-current={pageNumber === currentPage ? 'page' : undefined}
              class={`inline-flex h-9 w-9 items-center justify-center rounded-full text-sm font-semibold transition-colors ${
                pageNumber === currentPage
                  ? 'bg-slate-900 text-white'
                  : 'text-slate-500 hover:bg-slate-100 hover:text-slate-900'
              }`}
            >
              {pageNumber}
            </a>
          ))}
        </nav>
      )}

      <div class="mt-16 rounded-3xl border border-slate-100 bg-white px-6 py-8 text-center shadow-[0_24px_60px_-50px_rgba(15,23,42,0.6)] sm:px-10">
        <p class="font-sora text-lg font-semibold text-slate-900">Looking for a quick definition instead?</p>
        <p class="mt-2 text-sm leading-relaxed text-slate-500">
          Food noise, titration, shot day, maintenance dose — the whole vocabulary, in plain language.
        </p>
        <a
          href="/glossary"
          class="mt-5 inline-flex items-center rounded-full bg-slate-950 px-5 py-2.5 text-sm font-semibold text-white transition-all duration-300 ease-out-quint hover:-translate-y-0.5 hover:bg-slate-900"
        >
          Browse the GLP-1 glossary
        </a>
      </div>
    </main>

    <Footer />
  </div>
</Layout>
