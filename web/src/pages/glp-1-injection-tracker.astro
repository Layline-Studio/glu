---
import { Image } from 'astro:assets';
import Layout from '../layouts/Layout.astro';
import Footer from '../components/Footer.astro';
import StoreButtons from '../components/StoreButtons.astro';
import homeTrackers from '../assets/landing-page/home_trackers.png';

const faqs = [
  {
    question: 'What is a GLP-1 injection tracker?',
    answer:
      'A GLP-1 injection tracker is a log of your weekly shots: the date, dose, and injection site of every injection, usually alongside weight, side effects, and meals. It answers the questions treatment keeps asking — did I inject this week, which site is next, how long have I been on this dose — and gives your prescriber a real history instead of estimates from memory.',
  },
  {
    question: 'Why track more than just the shot?',
    answer:
      'Dose decisions are made on patterns: how your weight trends at each dose, when side effects cluster, whether appetite returns before the week ends. Logging weight, symptoms, and hunger alongside each dose turns titration appointments into data reviews. The shot alone tells your prescriber what you took; the rest tells them what it did.',
  },
  {
    question: 'Does Glu work with Wegovy, Ozempic, Zepbound, and Mounjaro?',
    answer:
      'Yes. Glu tracks any injectable GLP-1 medication schedule, including semaglutide (Wegovy, Ozempic) and tirzepatide (Zepbound, Mounjaro), plus compounded regimens as prescribed by your clinician. You set your medication, dose, and shot day; Glu handles reminders, dose history, and site rotation from there.',
  },
  {
    question: 'Is Glu free?',
    answer:
      'Glu is free to download on iOS and Android with core tracking included. Glu Pro adds advanced insights, reports for appointments, and full history at $9.99/month or $89.99/year.',
  },
  {
    question: 'Is my health data private?',
    answer:
      'Your data belongs to you. Glu does not sell personal data or use it for ad targeting, and you can export or delete your data and account directly from the app. See our privacy policy for the details.',
  },
];

const structuredData = [
  {
    '@context': 'https://schema.org',
    '@type': 'BreadcrumbList',
    itemListElement: [
      { '@type': 'ListItem', position: 1, name: 'Home', item: 'https://myglu.health/' },
      { '@type': 'ListItem', position: 2, name: 'GLP-1 Injection Tracker', item: 'https://myglu.health/glp-1-injection-tracker' },
    ],
  },
  {
    '@context': 'https://schema.org',
    '@type': 'FAQPage',
    mainEntity: faqs.map((faq) => ({
      '@type': 'Question',
      name: faq.question,
      acceptedAnswer: { '@type': 'Answer', text: faq.answer },
    })),
  },
];

const steps = [
  {
    title: 'Log the shot in one tap',
    body: 'Dose, date, and injection site, recorded on shot day in seconds. Site rotation stops being a memory game — last week’s spot is always on screen.',
  },
  {
    title: 'Note the week as it happens',
    body: 'Weight, side effects, meals, water, and how loud the food noise got. Small entries during the week, made where your phone already is.',
  },
  {
    title: 'See the pattern, not the noise',
    body: 'Weight trends by dose, symptoms lined up against dose changes, appetite across the injection week — the view your titration decisions actually need.',
  },
];

const trackedThings = [
  { label: 'Doses & shot day', detail: 'Reminders, full dose history, and titration timeline' },
  { label: 'Injection sites', detail: 'Rotation log across abdomen, thighs, and arms' },
  { label: 'Weight trend', detail: 'Weekly averages and trend lines, not single-day noise' },
  { label: 'Side effects', detail: 'Symptoms with timing relative to each dose' },
  { label: 'Meals & protein', detail: 'Portion-sized logging built for suppressed appetites' },
  { label: 'Habits', detail: 'Water, movement, and the daily basics that carry maintenance' },
];
---

<Layout
  title="GLP-1 Injection Tracker — Doses, Sites, Weight & Side Effects | Glu"
  description="Track your weekly GLP-1 shots with Glu: dose history, injection-site rotation, weight trends, and side effects for Wegovy, Ozempic, Zepbound, and Mounjaro — in one app built for treatment weeks."
  canonicalPath="/glp-1-injection-tracker"
  structuredData={structuredData}
>
  <div class="min-h-screen bg-slate-50 text-slate-900">
    <header class="sticky top-0 z-50 border-b border-slate-100 bg-white/80 backdrop-blur-xl">
      <div class="mx-auto max-w-screen-lg px-6 py-6 sm:px-8">
        <a href="/" class="inline-flex items-center gap-3">
          <img src="/app_icon.png" alt="Glu" class="h-8 w-8 rounded-xl shadow-sm" width="32" height="32" />
          <span class="font-sora text-lg font-semibold tracking-tight text-slate-900">Glu</span>
        </a>
      </div>
    </header>

    <main class="mx-auto w-full max-w-screen-lg px-6 pb-20 sm:px-8">
      <section class="grid items-center gap-10 pb-16 pt-16 sm:pt-20 lg:grid-cols-2">
        <div>
          <span class="inline-flex items-center gap-2 rounded-full bg-slate-900/5 px-3 py-1 text-xs font-semibold uppercase tracking-[0.2em] text-slate-700">
            GLP-1 injection tracker
          </span>
          <h1 class="mt-5 font-sora text-3xl font-semibold leading-tight tracking-tight text-slate-900 sm:text-4xl lg:text-[2.75rem]">
            Every shot, site, and side effect — one clean record
          </h1>
          <p class="mt-4 max-w-xl text-lg leading-relaxed text-slate-500">
            Weekly medication means weekly questions: did I inject, where, at what dose, and what
            did the week look like? Glu answers all of them with a five-minute shot-day routine —
            for Wegovy, Ozempic, Zepbound, and Mounjaro.
          </p>
          <div class="mt-8">
            <StoreButtons />
          </div>
          <p class="mt-4 text-sm text-slate-400">
            Free to download · iOS &amp; Android
          </p>
        </div>
        <div class="mx-auto w-full max-w-sm">
          <Image
            src={homeTrackers}
            alt="Glu app home screen showing GLP-1 dose tracking, weight trend, and daily habit trackers"
            width={480}
            class="w-full rounded-3xl shadow-[0_40px_80px_-40px_rgba(15,23,42,0.45)]"
            loading="eager"
          />
        </div>
      </section>

      <section class="border-t border-slate-200/80 py-16">
        <h2 class="font-sora text-2xl font-semibold tracking-tight text-slate-900 sm:text-3xl">
          How tracking works in Glu
        </h2>
        <div class="mt-10 grid gap-6 sm:grid-cols-3">
          {steps.map((step, index) => (
            <div class="rounded-3xl border border-slate-100 bg-white p-7 shadow-[0_24px_60px_-50px_rgba(15,23,42,0.6)]">
              <span class="inline-flex h-8 w-8 items-center justify-center rounded-full bg-slate-950 font-sora text-sm font-semibold text-white">
                {index + 1}
              </span>
              <h3 class="mt-4 font-sora text-base font-semibold text-slate-900">{step.title}</h3>
              <p class="mt-2 text-sm leading-relaxed text-slate-500">{step.body}</p>
            </div>
          ))}
        </div>
      </section>

      <section class="border-t border-slate-200/80 py-16">
        <h2 class="font-sora text-2xl font-semibold tracking-tight text-slate-900 sm:text-3xl">
          What Glu keeps track of
        </h2>
        <p class="mt-3 max-w-2xl text-slate-500">
          Treatment isn't just the injection. The record that makes appointments useful pairs your
          dose history with what happened between doses.
        </p>
        <div class="mt-10 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
          {trackedThings.map((item) => (
            <div class="rounded-2xl border border-slate-100 bg-white p-5">
              <p class="font-sora text-sm font-semibold text-slate-900">{item.label}</p>
              <p class="mt-1 text-sm leading-relaxed text-slate-500">{item.detail}</p>
            </div>
          ))}
        </div>
      </section>

      <section class="border-t border-slate-200/80 py-16">
        <h2 class="font-sora text-2xl font-semibold tracking-tight text-slate-900 sm:text-3xl">
          Prefer paper? Start with the free printable
        </h2>
        <p class="mt-3 max-w-2xl text-slate-500">
          We made a one-page printable shot tracker — eight weeks of doses, sites, weights, and
          side-effect notes. Free PDF, no email required. When you're ready for trends and
          reminders, the app is here.
        </p>
        <a
          href="/printable-glp-1-tracker"
          class="mt-6 inline-flex items-center rounded-full border border-slate-300 bg-white px-5 py-2.5 text-sm font-semibold text-slate-900 transition-all duration-300 ease-out-quint hover:-translate-y-0.5 hover:border-slate-400"
        >
          Get the printable tracker →
        </a>
      </section>

      <section class="border-t border-slate-200/80 py-16">
        <h2 class="font-sora text-2xl font-semibold tracking-tight text-slate-900 sm:text-3xl">
          Common questions
        </h2>
        <div class="mt-8 space-y-4">
          {faqs.map((faq) => (
            <details class="group rounded-2xl border border-slate-100 bg-white p-6">
              <summary class="cursor-pointer list-none font-sora text-base font-semibold text-slate-900">
                {faq.question}
              </summary>
              <p class="mt-3 text-sm leading-relaxed text-slate-500">{faq.answer}</p>
            </details>
          ))}
        </div>
      </section>

      <section class="rounded-3xl border border-slate-100 bg-white px-6 py-12 text-center shadow-[0_24px_60px_-50px_rgba(15,23,42,0.6)] sm:px-10">
        <h2 class="font-sora text-2xl font-semibold tracking-tight text-slate-900">
          Start your record this shot day
        </h2>
        <p class="mx-auto mt-3 max-w-md text-slate-500">
          The best week to start tracking was your first dose. The second best is this one.
        </p>
        <div class="mt-7 flex justify-center">
          <StoreButtons />
        </div>
      </section>
    </main>

    <Footer />
  </div>
</Layout>
